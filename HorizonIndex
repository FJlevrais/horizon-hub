local function RejoinGame()
	task.wait(1)
	local success, result = pcall(function()
		TeleportService:TeleportAsync(game.PlaceId, {LocalPlayer})
	end)
	if not success then
		SendNotificationToast("Failed to rejoin server. Try again later.")
		warn("Rejoin failed: " .. tostring(result))
	else
		SendNotificationToast("Rejoining server...")
	end
end

