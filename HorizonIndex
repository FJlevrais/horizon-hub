local ClientConfig = {
	Theme = "DefaultDark",
	ToggleKey = "RightShift"
}

local function LoadSavedSettings()
	if readfile and isfile and isfile(SAVE_FILE_NAME) then
		local success, content = pcall(readfile, SAVE_FILE_NAME)
		if success then
			local dataSuccess, decoded = pcall(function() return HttpService:JSONDecode(content) end)
			if dataSuccess and decoded then
				if decoded.Theme then ClientConfig.Theme = decoded.Theme end
				if decoded.ToggleKey then ClientConfig.ToggleKey = decoded.ToggleKey end
			end
		end
	end
end

local function SaveCurrentSettings()
	if writefile then
		local success, encoded = pcall(function() return HttpService:JSONEncode(ClientConfig) end)
		if success then
			pcall(writefile, SAVE_FILE_NAME, encoded)
		end
	end
end

LoadSavedSettings()

local function GetLiveViews(scriptId)
	local key = DATABASE_NAMESPACE .. tostring(scriptId)
	local fetchSuccess, liveData = pcall(function()
		return HttpService:GetAsync("https://kv.val.town/v1/entries/" .. key)
	end)
	if fetchSuccess and liveData and liveData ~= "" then
		local sanitized = liveData:gsub('[%p%c%s]', '')
		return tostring(tonumber(sanitized) or 0) .. " views"
	end
	return "1 views"
end

local function IncrementLiveViews(scriptId, currentViewsLabel)
	local key = DATABASE_NAMESPACE .. tostring(scriptId)
	task.spawn(function()
		local currentCount = 0
		local fetchSuccess, liveData = pcall(function()
			return HttpService:GetAsync("https://kv.val.town/v1/entries/" .. key)
		end)
		if fetchSuccess and liveData then
			currentCount = tonumber(liveData:gsub('[%p%c%s]', '')) or 0
		end
		local newCount = currentCount + 1
		pcall(function()
			HttpService:PostAsync("https://kv.val.town/v1/entries/" .. key, tostring(newCount), Enum.HttpContentType.ApplicationJson)
		end)
		task.defer(function()
			if currentViewsLabel then currentViewsLabel.Text = tostring(newCount) .. " views" end
		end)
	end)
end

