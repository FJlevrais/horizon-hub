-- =============================================================================
-- WINDOW DRAGGING ENGINE
-- =============================================================================
local DraggingEnabled, DragInput, DragStart, StartPosition
TopBar.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
		DraggingEnabled = true
		DragStart = input.Position
		StartPosition = FrameContainer.Position
		input.Changed:Connect(function()
			if input.UserInputState == Enum.UserInputState.End then DraggingEnabled = false end
		end)
	end
end)
TopBar.InputChanged:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch then DragInput = input end
end)
UserInputService.InputChanged:Connect(function(input)
	if input == DragInput and DraggingEnabled then
		local delta = input.Position - DragStart
		FrameContainer.Position = UDim2.new(StartPosition.X.Scale, StartPosition.X.Offset + delta.X, StartPosition.Y.Scale, StartPosition.Y.Offset + delta.Y)
	end
end)

