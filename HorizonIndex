	SendNotificationToast("Starting rejoin sequence...")
	RejoinGame()
end)

-- =============================================================================
-- INTERACTIVE WINDOW ACTION CONTROLS ENGINE
-- =============================================================================
local function ToggleHubVisibility()
	UI_Visible = not UI_Visible
	if UI_Visible then
		FrameContainer.Visible = true
		TweenService:Create(FrameContainer, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {GroupTransparency = 0}):Play()
	else
		local closeTween = TweenService:Create(FrameContainer, TweenInfo.new(0.25, Enum.EasingStyle.Quad), {GroupTransparency = 1})
		closeTween:Play()
		closeTween.Completed:Connect(function()
			if not UI_Visible then FrameContainer.Visible = false end
		end)
	end
end

MinimizeButton.MouseButton1Click:Connect(function()
	ToggleHubVisibility()
	SendNotificationToast("Horizon Hub minimized. Press [" .. ClientConfig.ToggleKey .. "] to reopen configuration panel.")
end)

UserInputService.InputBegan:Connect(function(input, processed)
	if processed then return end
	
	if ListeningForBind then
		if input.UserInputType == Enum.UserInputType.Keyboard then
			local keyName = input.KeyCode.Name
			ClientConfig.ToggleKey = keyName
			SaveCurrentSettings()
			ListeningForBind = false
			RenderScriptsViewEngine("")
		end
		return
	end
	
	if input.UserInputType == Enum.UserInputType.Keyboard and input.KeyCode.Name == ClientConfig.ToggleKey then
		ToggleHubVisibility()
	end
end)

