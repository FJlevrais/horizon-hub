local function ApplyColorThemeScheme()
	local activeConfig = Themes[CurrentTheme]
	FrameContainer.BackgroundColor3 = activeConfig.Background
	Sidebar.BackgroundColor3 = activeConfig.Sidebar
	TitleLabel.TextColor3 = activeConfig.Accent
	EmptyNoticeLabel.TextColor3 = activeConfig.MutedText
	ConsoleFrame.BackgroundColor3 = activeConfig.Background
	ConsoleHeader.BackgroundColor3 = activeConfig.Sidebar
	
	for _, childBtn in ipairs(Sidebar:GetChildren()) do
		if childBtn:IsA("TextButton") then
			if childBtn.Name == CurrentCategory then
				TweenService:Create(childBtn, TweenInfo.new(0.2), {BackgroundColor3 = activeConfig.Card, TextColor3 = activeConfig.Text, BackgroundTransparency = 0}):Play()
				if childBtn:FindFirstChild("SelectionBar") then 
					childBtn.SelectionBar.Visible = true 
					childBtn.SelectionBar.BackgroundColor3 = activeConfig.Accent
				end
			else
				TweenService:Create(childBtn, TweenInfo.new(0.2), {TextColor3 = activeConfig.MutedText, BackgroundTransparency = 1}):Play()
				if childBtn:FindFirstChild("SelectionBar") then childBtn.SelectionBar.Visible = false end
			end
		end
	end
end

