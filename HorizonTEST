local _HEX_STREAM = ""
local _XOR = 233

local _STREAM_BUFFER = {}
local _INDEX = 1

for i = 1, #_HEX_STREAM, 2 do
    local hex_pair = string.sub(_HEX_STREAM, i, i + 1)
    local decrypted_byte = tonumber(hex_pair, 16) ~ _XOR
    
    _STREAM_BUFFER[_INDEX] = string.char(decrypted_byte)
    _INDEX = _INDEX + 1
end

local final_source_string = table.concat(_STREAM_BUFFER)

-- Directly execute without wrapping in threads or modifying environments
local target_pipeline = loadstring or load
local chunk, fault = target_pipeline(final_source_string)

if chunk then
    chunk()
else
    warn("Compiler Engine Fault: " .. tostring(fault))
end
