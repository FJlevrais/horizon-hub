local _HEX_STREAM = ""
local _XOR = 174

local _STREAM_BUFFER = {}
local _INDEX = 1

for i = 1, #_HEX_STREAM, 2 do
    local hex_pair = string.sub(_HEX_STREAM, i, i + 1)
    local decrypted_byte = tonumber(hex_pair, 16) ~ _XOR
    
    _STREAM_BUFFER[_INDEX] = string.char(decrypted_byte)
    _INDEX = _INDEX + 1
end

local full_decompiled_string = table.concat(_STREAM_BUFFER)

-- BYPASS: We let them see the block text, but our compiler strips the fake 'return false' warning line at runtime!
